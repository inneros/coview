{
  "manifest_version": 3,
  "name": "coview",
  "version": "0.1.0",
  "description": "Dock a live chat with your Claude Code session into any page. Local only.",
  "permissions": ["storage"],
  "host_permissions": ["http://localhost:7777/*", "http://127.0.0.1:7777/*"],
  "background": { "service_worker": "background.js" },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
